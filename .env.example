# Copy to .env (dev), .env.staging or .env.prod and fill in real values.
# All three files are gitignored — never commit real credentials.

# Database (local docker compose values shown; use Neon credentials for staging/prod)
DB_HOST=db
DB_PORT=5432
DB_NAME=canopy
DB_USER=postgres
DB_PASSWORD=password
DB_SSLMODE=disable

# dev | staging | production
ENV=dev

# Transactional email for account invites and password resets.
# Leave RESEND_API_KEY empty in dev: emails are logged instead of sent and
# invite links can be copied from the admin UI.
RESEND_API_KEY=
EMAIL_FROM=Canopy <noreply@canopydata.app>
# Base URL used in emailed links; {org} is replaced with the organisation slug.
# Defaults: https://{org}.canopydata.app in staging/prod, localhost:5173 in dev.
FRONTEND_BASE_URL=

# Error monitoring
SENTRY_DSN=

# Ecotopia / Druid tracker integration
ECOTOPIA_USERNAME=
ECOTOPIA_PASSWORD=

# Inference: local | modal
INFERENCE_MODE=local
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Cloudflare R2 media storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
